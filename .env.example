# =============================================================
# FREE / LOCAL-MODEL EDITION — only ONE key needed
# =============================================================

# --- Pinecone (free tier: 1 index, 2 GB storage) ---
# Sign up at: https://app.pinecone.io
PINECONE_API_KEY=your-pinecone-key-here
PINECONE_INDEX_NAME=merger-kg-rag
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# --- Local embedding model (HuggingFace, no key, ~130 MB download) ---
EMBED_MODEL=BAAI/bge-small-en-v1.5
EMBED_DIM=384

# --- Local LLM via Ollama (no key, ~2 GB download) ---
# Install: https://ollama.com/download
# Then run: ollama pull llama3.2
LLM_BACKEND=ollama
LLM_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# --- Local reranker (FlashRank, no key, ~120 MB download) ---
FLASHRANK_MODEL=ms-marco-MiniLM-L-12-v2

# --- Pipeline tuning ---
RETRIEVAL_TOP_K=20
RERANK_TOP_N=5
RRF_K_CONSTANT=60

# ---------------------------------------------------------------
# OPTIONAL — only needed if you add NEW PDFs and want to re-parse
# them with LlamaParse. Your existing parsed markdown is already
# cached in data/parsed_markdown/ — you don't need this for the
# current 4-document corpus.
# ---------------------------------------------------------------
# LLAMA_CLOUD_API_KEY=llx-...

# ---------------------------------------------------------------
# OPTIONAL — only if you switch LLM_BACKEND=openai after topping
# up your OpenAI credits
# ---------------------------------------------------------------
# OPENAI_API_KEY=sk-...
